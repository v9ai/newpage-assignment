# Copy this file to .env.local and fill in the real key.
# .env.local is gitignored — never commit secrets.
# Load order: .env (defaults) then .env.local (overrides, wins).

# Required: OpenAI API key for the LLM (chat answers).
# The api fails fast at startup if this is missing.
OPENAI_API_KEY=sk-...

# Optional: any OpenAI-compatible endpoint/model (defaults shown).
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-5-mini

# Optional: local FastEmbed embedding model (384-dim ONNX).
# Changing it requires re-ingestion.
# EMBED_MODEL=BAAI/bge-small-en-v1.5
# EMBED_DIM=384

# Local services (compose defaults — no changes needed).
# DATABASE_URL=postgresql+psycopg://docchat:docchat@localhost:5432/docchat
# QDRANT_URL=http://localhost:6333
# QDRANT_COLLECTION=docchat_chunks

# Uploads: where files land and the server-side size cap (in MB).
# UPLOAD_DIR=./data/uploads
# MAX_UPLOAD_MB=25

# Chunking strategy for ingestion.
# CHUNK_SIZE=512
# CHUNK_OVERLAP=64

# Retrieval tuning.
# RETRIEVAL_TOP_K=5
# RETRIEVAL_SCORE_THRESHOLD=0.3

# Chat history condensation budget (tokens).
# CHAT_TOKEN_BUDGET=6000
