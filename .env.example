# Copy this file to .env.local and fill in the real key.
# .env.local is gitignored — never commit secrets.

# Required: OpenAI API key for the LLM (chat answers)
OPENAI_API_KEY=sk-...

# Optional: any OpenAI-compatible endpoint/model (defaults shown)
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-5-mini

# Optional: local FastEmbed embedding model (changing it requires re-ingestion)
# EMBED_MODEL=BAAI/bge-small-en-v1.5

# Local services (compose defaults — no changes needed)
# DATABASE_URL=postgresql+psycopg://docchat:docchat@localhost:5432/docchat
# QDRANT_URL=http://localhost:6333
